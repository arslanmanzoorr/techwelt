# ── Techwelt environment variables ──────────────────────────────────────────
# Copy to .env.local for local dev, and set these in Vercel for production.

# Neon Postgres connection string (https://neon.tech — free tier).
# Looks like: postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Password for the /admin dashboard login.
ADMIN_PASSWORD=

# Optional: a random secret used to sign the admin session cookie.
# If omitted, ADMIN_PASSWORD is used. Set a long random string in production.
ADMIN_SECRET=

# Vercel Blob token for news cover-image uploads.
# On Vercel: create a Blob store (Storage tab) and it's injected automatically.
# Locally: copy it from the Vercel dashboard into .env.local to test uploads.
BLOB_READ_WRITE_TOKEN=
